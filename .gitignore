# ============================================================================
# AggreKV CASES Artifact - .gitignore
# ============================================================================
# The source tree is tracked in git; blktrace dataset (6.2 GB) and build
# outputs are excluded and distributed separately via a Zenodo dataset
# record (CC-BY-4.0). See README.md §"Distribution channel" for the
# split-archive strategy.
#
#  - download-blktrace.sh at the artifact root IS tracked; it is the official
#    fetcher for the Zenodo record (44 individual file URLs + SHA256 manifest).
#  - block_ssd/blktrace/ is the only large dataset directory; it is filled
#    by `bash download-blktrace.sh` per INSTALL.md §3.1.
# ============================================================================

# --- Bundled blktrace dataset (6.2 GB) — Zenodo dataset record ---
# Filled by `bash download-blktrace.sh` (see INSTALL.md §3.1).
block_ssd/blktrace/

# --- Per-experiment result directories (regenerated by each sub-driver) ---
hash_kvssd/hash_kvssd_results/
lsmtree_kvssd/lsmtree_test_results/
block_ssd/blktrace_test_results/
block_ssd/blktrace_summary/

# --- Legacy top-level aggregation directory ---
results/

